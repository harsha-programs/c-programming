#include<stdio.h>
int main() {   
    int n, i;
    int arr[i] ;
    printf("Enter number of elements: ");           
    scanf("%d", &n);
    printf("Enter elements of the array:\n");  
    for(i = 0; i < n; i++) 
        scanf("%d", &arr[i]);
    int max = -1;
    for ( int i =0 ; i< n ; i++) 
        if(arr[i] > max) 
            max = arr[i];
    printf("Maximum element in the array: %d\n", max);  
    return 0;
}   
