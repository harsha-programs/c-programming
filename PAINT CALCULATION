#include <stdio.h>

int main() {
    float length, breadth, height, area, paint_required;

    printf("Enter length, breadth and height of room (in meters): ");
    scanf("%f %f %f", &length, &breadth, &height);

    area = 2 * height * (length + breadth);   // Wall area
    paint_required = area / 10;   // Assume 1 litre covers 10 sq.m

    printf("Total wall area = %.2f sq.m\n", area);
    printf("Paint required = %.2f litres\n", paint_required);

    return 0;
}
