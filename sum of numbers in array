#include<stdio.h>
int main() {   
    int n, i;
    int arr[i] ;
    printf("Enter number of elements: ");           
    scanf("%d", &n);
    printf("Enter elements of the array:\n");  
    for(i = 0; i < n; i++) 
        scanf("%d", &arr[i]);
    int sum = 0;
    for ( int i =0 ; i< n ; i++) 
        sum = sum + arr[i];
    printf("Sum of elements in the array: %d\n", sum);
    return 0;
}   
