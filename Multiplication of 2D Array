#include <stdio.h>

int main() {
    int m, n, q;

    printf("Enter rows and columns of matrix A: ");
    scanf("%d %d", &m, &n);

    printf("Enter columns of matrix B: ");
    scanf("%d", &q);

    int A[m][n], B[n][q], C[m][q];

    // Input A
    printf("Enter elements of matrix A:\n");
    for(int i = 0; i < m; i++) {
        for(int j = 0; j < n; j++) {
            scanf("%d", &A[i][j]);
        }
    }

    // Input B
    printf("Enter elements of matrix B:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < q; j++) {
            scanf("%d", &B[i][j]);
        }
    }

    // Multiplication
    for(int i = 0; i < m; i++) {
        for(int j = 0; j < q; j++) {
            C[i][j] = 0;
            for(int k = 0; k < n; k++) {
                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }

    // Output
    printf("Result matrix:\n");
    for(int i = 0; i < m; i++) {
        for(int j = 0; j < q; j++) {
            printf("%d ", C[i][j]);
        }
        printf("\n");
    }

    return 0;
}
